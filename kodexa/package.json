{
  "name": "kodexa",
  "displayName": "Kodexa",
  "description": "Agentic AI IDE Assistant",
  "version": "0.0.1",
  "publisher": "kodexa",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kodexa-sidebar",
          "title": "Kodexa",
          "icon": "src/assets/icon.svg"
        }
      ]
    },
    "views": {
      "kodexa-sidebar": [
        {
          "type": "webview",
          "id": "kodexa.sidebar",
          "name": "Kodexa",
          "icon": "$(debug-alt)"
        }
      ]
    },
    "commands": [
      {
        "command": "kodexa.debug",
        "title": "Debug with AI",
        "icon": "$(debug-alt)"
      },
      {
        "command": "kodexa.explain",
        "title": "Explain Error",
        "icon": "$(question)"
      },
      {
        "command": "kodexa.optimize",
        "title": "Optimize File",
        "icon": "$(zap)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
